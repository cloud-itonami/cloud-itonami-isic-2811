{:paths ["src"]
 ;; langgraph brings langchain transitively (both zero-/single-dep,
 ;; all .cljc -> portable to JVM / SCI / ClojureScript / GraalVM). It lives
 ;; in the kotoba-lang org of this workspace (transferred + renamed from
 ;; com-junkawasaki/langgraph-clj / com-junkawasaki/langchain-clj). This
 ;; repo is standalone (forkable outside the workspace); the :local/root
 ;; paths only resolve inside the monorepo checkout — a standalone fork
 ;; should override them with git coordinates.
 :deps {io.github.kotoba-lang/langgraph
        {:local/root "../../kotoba-lang/langgraph"}
        io.github.kotoba-lang/robotics
        {:local/root "../../kotoba-lang/robotics"}
        ;; REAL engineering-simulation dependency (ADR-2607999500, this
        ;; actor's first robotics namespace -- see `autoparts.robotics`/
        ;; `deviceassembly.robotics` for the prior instances of this
        ;; same dependency): turbine.robotics now actually calls
        ;; physics-2d/world-step -- a real, tested time-stepped
        ;; rigid-body impulse solver -- to run a real connecting-rod/
        ;; cylinder-head bolt tensile proof-load pull-test simulation,
        ;; ADDITIONAL to (never replacing) the existing self-reported
        ;; type-rules evidence checklist (`turbine.facts`) and the
        ;; existing symbolic dimensional-tolerance field comparison
        ;; (`turbine.registry`). This vertical has no design-library
        ;; sibling repo, so the physics module is built directly in
        ;; turbine.robotics and the ONLY new physics dependency is
        ;; physics-2d itself, taken as a real pinned git-coordinate dep
        ;; (not :local/root) so this repo stays forkable standalone
        ;; outside the monorepo -- the same reasoning `autoparts.
        ;; robotics`/`deviceassembly.robotics` already established,
        ;; using the SAME fleet-standard SHA pin those repos currently
        ;; use.
        io.github.kotoba-lang/physics-2d
        {:git/url "https://github.com/kotoba-lang/physics-2d.git"
         :sha "03b6c23c8d9aa36b92a8130fd3e37fc2548b4d26"}
        ;; langchain-store: the shared langchain.db store seam (EDN-blob
        ;; codec + identity schema + event-log helpers) that ~190 actors
        ;; hand-roll; turbine.store is an adopter (ADR-2607141600).
        io.github.kotoba-lang/langchain-store
        {:local/root "../../kotoba-lang/langchain-store"}}
 :aliases
 {;; offline workspace dev -- pin transitive langchain to local checkout
  :dev {:override-deps
        {io.github.kotoba-lang/langchain
         {:local/root "../../kotoba-lang/langchain"}}}
  ;; clojure -M:dev:run  -> drive the demo through one OperationActor
  :run {:main-opts ["-m" "turbine.sim"]}
  :export {:main-opts ["-m" "turbine.export-run"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; static analysis -- clj-kondo from deps (no binary), errors fail CI.
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main"
                        "--lint" "src" "test"
                        "--fail-level" "error"]}}}
